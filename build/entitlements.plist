<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Node.js JITs JavaScript; without these it crashes under the hardened
       runtime that notarization requires. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- The bundle mixes our Developer ID signature (Python, the app) with the
       vendored Node + CLI binaries; allow the loader to bind them. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Child agent processes (claude/codex) inherit env we set (PATH). -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
