# Required on the recipient's machine (where the daemon and the agent run).
# The broker does NOT need this.
ANTHROPIC_API_KEY=your-key-here

# Required on the broker's machine. Any random 32+ char string.
# Senders/recipients do not need this — they just hold tokens issued by the broker.
DISPATCH_JWT_SECRET=change-me-to-a-long-random-string

# Required on the broker's machine. Postgres connection URL.
# Locally, point at a Docker Postgres (see README). On Railway, the Postgres
# add-on injects this automatically as DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/dispatch

# Required on the broker (browser sign-in via Clerk + Google):
# CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_FRONTEND_API=your-app.clerk.accounts.dev    (no https://)
# CLERK_JWT_TEMPLATE=dispatch                       (must include `email` claim)
# CLERK_JWT_AUDIENCE=                               (optional; set if your template defines an aud)

# Optional (broker):
# Public URL of the broker. Used by /install.sh.
# DISPATCH_PUBLIC_URL=https://dispatch-production.up.railway.app
#
# Resend API key for sending *invitation* emails (sign-in no longer uses email).
# If unset, the invite link is logged and returned in the API response (dev mode).
# RESEND_API_KEY=re_...
# RESEND_FROM=Dispatch <noreply@your-domain.com>
#
# What `curl <broker>/install.sh | bash` points `pipx install` at. Defaults
# to a public GitHub repo; override with your repo or a wheel URL.
# DISPATCH_DAEMON_INSTALL=git+https://github.com/your-org/dispatch.git

# Optional: directory the agent is allowed to read/write in on the recipient.
# DISPATCH_WORKSPACE=/absolute/path/to/sandbox

# Optional (daemon): override broker URL and token via env instead of CLI flags.
# DISPATCH_BROKER=https://your-broker.example.com
# DISPATCH_TOKEN=eyJhbGciOi...
